# Copy this to .env.local and fill in real values for local dev.
# Set the same vars in Vercel → Project → Settings → Environment Variables.

# Get your key at: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Who receives signup notification emails
NOTIFY_EMAIL=himanshitomar@icloud.com

# The "from" address — must be verified in your Resend account.
# Use the Resend sandbox (onboarding@resend.dev) while testing before DNS is set up.
FROM_EMAIL=onboarding@resend.dev
